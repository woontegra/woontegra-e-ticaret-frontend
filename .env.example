# =============================================================================
# Woontegra Commerce Web — Environment Variables
# Copy to .env and fill in values. See docs/ENVIRONMENT.md for details.
# =============================================================================

# --- API base URL (required for production build) ---
# Local development (Vite proxy handles /api when localhost):
VITE_API_URL=http://localhost:3001

# Production — Railway / custom API domain:
# VITE_API_URL=https://api.example.com

# --- Notes ---
# - VITE_* vars are baked in at build time (npm run build).
# - Rebuild web after changing VITE_API_URL.
# - Same-origin deploy (nginx proxies /api): set VITE_API_URL empty or omit;
#   browser uses relative /api paths only if client supports it — prefer full URL.
# - SPA routing: vercel.json / nginx.conf handle /* → index.html
